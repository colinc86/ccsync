profiles:
    default:
        description: Primary config
    work: {}
jsonFiles:
    ~/.claude.json:
        include:
            - $.autoUpdates
            - $.theme
            - $.installMethod
            - $.companion
            - $.mcpServers
            - $.enabledPlugins
            - $.claudeAiMcpEverConnected
        exclude:
            - $.projects
            - $.oauthAccount
            - $.userID
            - $.accountUuid
            - $.organizationUuid
            - $.customApiKeyResponses
            - $.hasCompletedOnboarding
            - $.hasCompletedProjectOnboarding
            - $.lastOnboardingVersion
            - $.hasSeenGADisclaimer
            - $.hasSeenClaudeHaiku4
            - $.hasSeenOpus4
            - $.hasSeenSonnet4
            - $.hasSeenReleaseNotes
            - $.lastReleaseNotesSeen
            - $.tipsHistory
            - $.sessionId
            - $.lastSessionId
            - $.currentSessionId
            - $.firstStartTime
            - $.lastStartTime
            - $.startTimestamp
            - $.startTimestamps
            - $.numStartups
            - $.claudeCodeFirstTokenDate
            - $.promptQueueUseCount
            - $.lastUsedModel
            - $.lastUsedAt
            - $.lastKnownVersion
            - $.lastAutoUpdateCheck
            - $.installedFeatures
            - $.mcpContextUris
            - $.cachedGrowthBookFeatures
            - $.cachedStatsigGates
            - $.cachedStatsigExperiments
            - $.cachedStatsigLayers
            - $.cachedStatsigDynamicConfigs
            - $.statsigStableId
            - $.cachedChangelog
            - $.subscriptionNoticeCount
            - $.hasAvailableSubscription
            - $.hasAvailableMaxSubscription
            - $.hasReachedMaxSubscriptionLimit
            - $.isRateLimited
            - $.isRateLimitedWithFallback
        redact:
            - $.mcpServers.*.env.*
            - $..apiKey
            - $..token
            - $..secret
            - $..password
    ~/.claude/settings.json:
        include:
            - $
        exclude:
            - $.permissions.allow
            - $.permissions.deny
            - $.permissions.ask
        redact:
            - $.statusLine.command
defaultSyncignore: |
    # ephemeral / machine-local scratch
    .current-session-id
    .last-seen-version
    .last-*
    .DS_Store
    .lock
    *.bak
    cache-*.dat
    cache-*.last
    sparkline-*.dat
    sparkline-*.last
    statusline-mode-*
    statusline-color-*
    statusline-auto-sticky-*
    statusline-command.sh
    stats-cache.json
    history.jsonl
    mcp-needs-auth-cache.json
    # runtime-state directories — regenerated per machine
    backups/
    cache/
    debug/
    downloads/
    file-history/
    ide/
    logs/
    paste-cache/
    plugins/
    projects/
    session-by-ccpid/
    session-env/
    sessions/
    shell-snapshots/
    tasks/
    telemetry/
    todos/
    # machine-local config override — never sync
    settings.local.json
    # large personal work products — opt back in per profile if desired
    research/
    plans/
